# Frontend Environment Variables
# Copy this file to .env.local and customize for your local development

# Development Server Configuration
# Port for the Vite dev server
VITE_PORT=3000

# Backend API Configuration
# Host where the backend API is running
VITE_API_HOST=localhost

# Port where the backend API is running
VITE_API_PORT=8777

# WebSocket Configuration (optional)
# Port for WebSocket connection (defaults to VITE_API_PORT if not set)
# VITE_WS_PORT=8777

# Production Configuration (optional)
# These are typically set during build/deployment, not in local .env files

# Production API URL (leave empty to use relative URLs)
# VITE_API_URL=

# Production WebSocket URL (leave empty to auto-detect from location)
# VITE_WS_URL=

# Build Configuration
# Generate source maps in production build
VITE_GENERATE_SOURCEMAP=false
